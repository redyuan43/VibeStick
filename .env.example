# VibeStick local configuration example.
# Copy to .env for local shells if needed. Do not put real secrets in git.
# Empty values mean "use the built-in default" unless a comment says the value is required.

# REQUIRED -- fill these.
VIBE_STICK_PROVIDER=auto
# Generate with: openssl rand -hex 32
VIBE_STICK_BRIDGE_TOKEN=
# Stable identity returned by /health for firmware bridge selection.
VIBE_STICK_BRIDGE_ID=
VIBE_STICK_BRIDGE_LABEL=
# Set to on only if you want real Claude 5H/7D usage and Claude Code is installed/logged in.
VIBE_STICK_CLAUDE_USAGE=off
# Recommended ASR for China: SiliconFlow, OpenAI-compatible.
# Get a key at https://cloud.siliconflow.cn/i/7ZCoy9fU
VIBE_STICK_ASR_PROVIDER=openai-compatible
VIBE_STICK_ASR_BASE_URL=https://api.siliconflow.cn/v1
VIBE_STICK_ASR_API_KEY=
VIBE_STICK_ASR_MODEL=FunAudioLLM/SenseVoiceSmall

# OPTIONAL -- defaults are fine, leave empty to use defaults.
VIBE_STICK_PROJECT_ROOT=
VIBE_STICK_PROJECT_NAME=
VIBE_STICK_MAX_RECORDING_AUDIO_BYTES=2000000
VIBE_STICK_CLAUDE_USAGE_INTERVAL_SECONDS=300
CLAUDE_CODE_OAUTH_TOKEN=
VIBE_STICK_ASR_LANGUAGE=zh
VIBE_STICK_ASR_TIMEOUT_SECONDS=15
VIBE_STICK_ASR_ATTEMPTS=2

# Optional overseas Groq ASR preset.
# VIBE_STICK_ASR_PROVIDER=groq
# VIBE_STICK_ASR_BASE_URL=https://api.groq.com/openai/v1
# VIBE_STICK_ASR_API_KEY=
# VIBE_STICK_ASR_MODEL=whisper-large-v3-turbo

# Legacy Groq-specific aliases remain supported.
VIBE_STICK_GROQ_API_KEY=
VIBE_STICK_GROQ_MODEL=whisper-large-v3-turbo
VIBE_STICK_GROQ_LANGUAGE=zh

# Optional local ASR command. The command receives the recording session JSON on stdin.
VIBE_STICK_TRANSCRIBE_CMD=
VIBE_STICK_TRANSCRIBE_TIMEOUT_SECONDS=120

# Recording behavior.
VIBE_STICK_RECORDING_USE_MAC_MIC=1
VIBE_STICK_AUTO_ENTER=0
